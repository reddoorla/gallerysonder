# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.

# Toggle the homepage intro animation (true | false)
VITE_USE_INTRO = false

# Skip the cookie-consent modal locally. When true, no consent UI shows and —
# because analytics are consent-gated — no GTM/FB Pixel loads. Leave unset (or
# false) in production so the modal appears and tracking is opt-in.
VITE_DISABLE_COOKIE_CONSENT = true

# Google Maps Embed API key for the ContentWidthMedia "embed" map variation.
# This key is necessarily public (it ships in the iframe URL), so it MUST be
# locked down in the GCP console with HTTP-referrer + "Maps Embed API" restrictions.
# Also set this in the Netlify site env vars, or the embedded map renders blank.
VITE_GOOGLE_MAPS_EMBED_KEY = your-maps-embed-key

# Canonical origin used to build absolute URLs in /sitemap.xml. Prerendering
# can't read the real host, so set this to the production domain (no trailing
# slash). Defaults to https://www.gallerysonder.com if unset.
VITE_SITE_URL = https://www.gallerysonder.com
