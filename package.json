{
	"name": "sveltekit-starter-prismic-minimal",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"dev": "concurrently \"pnpm:vite:dev\" \"pnpm:slicemachine\" --prefix-colors blue,magenta",
		"vite:dev": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . --plugin prettier-plugin-svelte . && eslint .",
		"format": "prettier --write . --plugin prettier-plugin-svelte .",
		"slicemachine": "start-slicemachine",
		"test": "pnpm test:smoke",
		"test:smoke": "playwright install chromium && playwright test"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@playwright/test": "^1.60.0",
		"@slicemachine/adapter-sveltekit": "^0.3.38",
		"@sveltejs/adapter-netlify": "^6.0.4",
		"@sveltejs/kit": "^2.0.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@tailwindcss/postcss": "^4.1.18",
		"@types/node": "^25.9.3",
		"autoprefixer": "^10.4.19",
		"concurrently": "^9.2.3",
		"eslint": "^10.4.0",
		"postcss": "^8.4.38",
		"prettier": "^3.1.1",
		"prettier-plugin-svelte": "^3.1.2",
		"sharp": "^0.33.5",
		"slice-machine-ui": "^2.20.4",
		"svelte": "^5.46.0",
		"svelte-check": "^4.3.4",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.3.3",
		"typescript-svelte-plugin": "^0.3.36",
		"vite": "^7.3.0"
	},
	"type": "module",
	"dependencies": {
		"@google-analytics/data": "^5.2.0",
		"@lucide/svelte": "^1.20.0",
		"@prismicio/client": "^7.3.1",
		"@prismicio/svelte": "^2.0.0",
		"@reddoorla/maintenance": "^0.67.0",
		"@zerodevx/svelte-img": "^2.1.2",
		"flatpickr": "^4.6.13",
		"svelte-gestures": "^5.2.2"
	},
	"packageManager": "pnpm@11.8.0"
}
